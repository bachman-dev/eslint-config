{
  "name": "@bachman-dev/eslint-config",
  "version": "4.0.0",
  "description": "",
  "homepage": "https://github.com/bachman-dev/eslint-config",
  "author": "Collin Bachman <collin.r68zdn9d@bachman.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bachman-dev/eslint-config"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist/**/*.{mjs,d.mts}"
  ],
  "scripts": {
    "build": "tsdown --dts --format esm src/index.ts",
    "build:docs": "tsx ./scripts/docs.ts && prettier --write ./src/rules/README.md ./src/rules/naming-conventions.md",
    "lint": "tsdown --dts --format esm src/index.ts && eslint . && prettier --check .",
    "lint:ci": "eslint --fix . && prettier --write .",
    "lint:fix": "tsdown --dts --format esm src/index.ts && eslint --fix . && prettier --write ."
  },
  "peerDependencies": {
    "typescript-eslint": "^8.56.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.2",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.3",
    "tsdown": "0.21.10",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.1"
  },
  "dependencies": {
    "eslint": "^10.0.0"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
